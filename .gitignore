# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Environment files
*.env
# Ignore .env files in subdirectories
**/*.env

# Backend environment config (non-dotfile, NOT caught by *.env)
backend/config.env

# Node modules
node_modules
/backend/node_modules

# Distribution files
dist
dist-ssr
*.local

# Editor directories and files
.*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# User-uploaded images (runtime data, not for version control)
backend/uploads/*
!backend/uploads/.gitkeep

# ML model large binary files (use Git LFS or external storage)
Dermalens-model/*.bin
Dermalens-model/*.h5
Dermalens-model/*.dll
Dermalens-model/node_modules/
Dermalens-model/package-lock.json

# Junk / stray files
samsung.js
.env copy
