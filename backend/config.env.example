# Backend Environment Configuration Template
# Copy this file to config.env and fill in your real values.
# NEVER commit config.env to version control.

PORT=5000

# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority&appName=<appName>

# JWT Secret — use a long, random string (e.g. generated with: openssl rand -hex 64)
JWT_SECRET=your_super_secret_jwt_key_here_replace_with_something_long_and_random

# Google Gemini AI API Key
# Get one at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Override model path if not using the default relative location
# MODEL_PATH=file://../Dermalens-model/model.json

# Gmail OAuth2 credentials (for appointment email notifications)
# Set up at: https://console.cloud.google.com/
GMAIL_CLIENT_ID=your_gmail_oauth_client_id.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=your_gmail_oauth_client_secret
GMAIL_REDIRECT_URI=https://developers.google.com/oauthplayground
GMAIL_REFRESH_TOKEN=your_gmail_refresh_token

# Gmail sender account
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_gmail_app_password
